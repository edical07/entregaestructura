package com.example.edical.modelo;

/**
 * Modelo de datos que representa a un usuario en el sistema.
 * Se utiliza para gestionar la información de perfil y autenticación.
 */
public class UsuarioModelo {
    // Nombre completo del usuario
    String nombre;
    // Dirección de correo electrónico del usuario
    String correo;
    // Contraseña de la cuenta del usuario
    String contrasena;

    /**
     * Constructor vacío requerido por Firebase para la conversión de datos.
     */
    public UsuarioModelo() {
    }

    /**
     * Constructor para inicializar un nuevo usuario con sus datos básicos.
     * 
     * @param nombre Nombre del usuario.
     * @param correo Correo electrónico.
     * @param contrasena Contraseña de acceso.
     */
    public UsuarioModelo(String nombre, String correo, String contrasena) {
        this.nombre = nombre;
        this.correo = correo;
        this.contrasena = contrasena;
    }

    /**
     * Obtiene el nombre del usuario.
     * @return El nombre almacenado.
     */
    public String getNombre() {
        return nombre;
    }

    /**
     * Actualiza el nombre del usuario.
     * @param nombre El nuevo nombre.
     */
    public void setNombre(String nombre) {
        this.nombre = nombre;
    }

    /**
     * Obtiene el correo electrónico del usuario.
     * @return El correo electrónico.
     */
    public String getCorreo() {
        return correo;
    }

    /**
     * Actualiza el correo electrónico del usuario.
     * @param correo El nuevo correo.
     */
    public void setCorreo(String correo) {
        this.correo = correo;
    }

    /**
     * Obtiene la contraseña del usuario.
     * @return La contraseña almacenada.
     */
    public String getContrasena() {
        return contrasena;
    }

    /**
     * Actualiza la contraseña del usuario.
     * @param contrasena La nueva contraseña.
     */
    public void setContrasena(String contrasena) {
        this.contrasena = contrasena;
    }
}
